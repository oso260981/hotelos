        INNER JOIN pisos p 
            ON p.id = h.piso_id
        LEFT JOIN estados_habitacion eh 
            ON eh.id = h.estado_id
        LEFT JOIN huespedes hu 
            ON hu.id = r.huesped_id
        WHERE r.estado_registro IN (\'DISPONIBLE\', \'CHECKIN\')
        ORDER BY p.piso ASC, h.numero ASC
    ', 0)
